# Copy this file to .env and fill in your API keys

# OpenRouter API Key (get at: https://openrouter.ai/keys)
# Used to fetch ranking/usage data from OpenRouter
OPENROUTER_API_KEY=

# LLM Stats API Key (get at: https://llm-stats.com/developer)
# Used to fetch benchmark data from LLM Stats
LLMSTATS_API_KEY=

# Server port (default: 3000)
PORT=3000
